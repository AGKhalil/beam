# --- Dashboard ---

cmd_dashboard() {
    local state
    state=$(read_state)

    local spaces
    spaces=$(echo "$state" | jq -r '.spaces | keys[]' 2>/dev/null || true)

    if [[ -z "$spaces" ]]; then
        echo ""
        printf "  ${BOLD_CYAN}beam${RESET}\n"
        echo ""
        hint "No spaces yet."
        hint "Create one: ${BOLD}beam space create <name>${RESET}"
        echo ""
        return
    fi

    local has_dead=false

    echo ""
    printf "  ${BOLD_CYAN}beam${RESET}\n"

    while IFS= read -r space; do
        echo ""
        printf "  ${BOLD_WHITE}%s${RESET}\n" "$space"

        local sessions
        sessions=$(echo "$state" | jq -r ".spaces[\"$space\"].sessions // {} | keys[]" 2>/dev/null || true)

        if [[ -z "$sessions" ]]; then
            hint "  (empty)"
            continue
        fi

        while IFS= read -r session; do
            local s_status pid lc ls_port rc rs s_host
            s_status=$(echo "$state" | jq -r ".spaces[\"$space\"].sessions[\"$session\"].status")
            pid=$(echo "$state" | jq -r ".spaces[\"$space\"].sessions[\"$session\"].pid // \"null\"")
            s_host=$(echo "$state" | jq -r ".spaces[\"$space\"].sessions[\"$session\"].host")
            lc=$(echo "$state" | jq -r ".spaces[\"$space\"].sessions[\"$session\"].local_client_port")
            ls_port=$(echo "$state" | jq -r ".spaces[\"$space\"].sessions[\"$session\"].local_server_port")
            rc=$(echo "$state" | jq -r ".spaces[\"$space\"].sessions[\"$session\"].remote_client_port")
            rs=$(echo "$state" | jq -r ".spaces[\"$space\"].sessions[\"$session\"].remote_server_port")

            if [[ "$s_status" == "live" ]]; then
                local health
                health=$(check_health "$pid" "$lc" "$ls_port")
                if [[ "$health" == "healthy" ]]; then
                    printf "  ${GREEN}●${RESET}  %-32s ${DIM}%s${RESET}  %s:%s, %s:%s  ${GREEN}healthy${RESET}\n" \
                        "$session" "$s_host" "$lc" "$rc" "$ls_port" "$rs"
                else
                    has_dead=true
                    printf "  ${RED}●${RESET}  %-32s ${DIM}%s${RESET}  %s:%s, %s:%s  ${BOLD_RED}DEAD${RESET}\n" \
                        "$session" "$s_host" "$lc" "$rc" "$ls_port" "$rs"
                fi
            else
                printf "  ${DIM}○${RESET}  ${DIM}%-32s %s${RESET}\n" "$session" "$s_host"
            fi
        done <<< "$sessions"
    done <<< "$spaces"

    if [[ "$has_dead" == true ]]; then
        echo ""
        warn "Dead tunnels detected. Run ${BOLD}beam hydrate${RESET}"
    fi
    echo ""
}

# --- Hydrate ---

cmd_hydrate() {
    local state
    state=$(read_state)

    local spaces
    spaces=$(echo "$state" | jq -r '.spaces | keys[]' 2>/dev/null || true)

    if [[ -z "$spaces" ]]; then
        hint "No spaces exist."
        return
    fi

    local found_live=false
    local hydrated_ports=()

    echo ""
    label "  Hydrating"
    echo ""

    while IFS= read -r space; do
        local sessions
        sessions=$(echo "$state" | jq -r ".spaces[\"$space\"].sessions // {} | keys[]" 2>/dev/null || true)
        [[ -z "$sessions" ]] && continue

        while IFS= read -r session; do
            local s_status
            s_status=$(echo "$state" | jq -r ".spaces[\"$space\"].sessions[\"$session\"].status")
            [[ "$s_status" != "live" ]] && continue

            found_live=true

            local pid lc ls rc rs host
            pid=$(echo "$state" | jq -r ".spaces[\"$space\"].sessions[\"$session\"].pid // \"null\"")
            lc=$(echo "$state" | jq -r ".spaces[\"$space\"].sessions[\"$session\"].local_client_port")
            ls=$(echo "$state" | jq -r ".spaces[\"$space\"].sessions[\"$session\"].local_server_port")
            rc=$(echo "$state" | jq -r ".spaces[\"$space\"].sessions[\"$session\"].remote_client_port")
            rs=$(echo "$state" | jq -r ".spaces[\"$space\"].sessions[\"$session\"].remote_server_port")
            host=$(echo "$state" | jq -r ".spaces[\"$space\"].sessions[\"$session\"].host")

            local health
            health=$(check_health "$pid" "$lc" "$ls")

            if [[ "$health" == "healthy" ]]; then
                printf "  ${GREEN}●${RESET}  %s  ${DIM}already healthy${RESET}\n" "$session"
                continue
            fi

            local port_conflict=false
            for hp in "${hydrated_ports[@]:-}"; do
                if [[ "$hp" == "$lc" || "$hp" == "$ls" ]]; then
                    port_conflict=true
                    break
                fi
            done

            if [[ "$port_conflict" == true ]]; then
                printf "  ${YELLOW}!${RESET}  %s  ${DIM}skipped (port conflict)${RESET}\n" "$session"
                continue
            fi

            if [[ "$pid" != "null" ]]; then
                kill_tunnel "$pid" "$lc" "$ls"
            fi

            printf "  ${DIM}…${RESET}  %s  ${DIM}reconnecting${RESET}" "$session"
            local new_pid=""
            new_pid=$(start_tunnel "$host" "$lc" "$rc" "$ls" "$rs" 2>&1) || true

            if [[ -n "$new_pid" && "$new_pid" != "" ]]; then
                state=$(read_state)
                state=$(echo "$state" | jq ".spaces[\"$space\"].sessions[\"$session\"].pid = $new_pid")
                write_state "$state"
                hydrated_ports+=("$lc" "$ls")
                printf "\r\033[K  ${GREEN}●${RESET}  %s  ${GREEN}reconnected${RESET}\n" "$session"
            else
                printf "\r\033[K  ${RED}✗${RESET}  %s  ${RED}failed${RESET}\n" "$session"
            fi
        done <<< "$sessions"
    done <<< "$spaces"

    if [[ "$found_live" == false ]]; then
        hint "No live sessions to hydrate."
    fi
    echo ""
}

# --- Usage ---

show_usage() {
    echo ""
    printf "  ${BOLD_CYAN}beam${RESET} ${DIM}- SSH tunnel manager${RESET}\n"
    echo ""
    printf "  ${BOLD}Usage${RESET}\n"
    printf "    ${BOLD_WHITE}beam${RESET}                            ${DIM}Dashboard${RESET}\n"
    printf "    ${BOLD_WHITE}beam${RESET} space ls|create|rm         ${DIM}Manage spaces${RESET}\n"
    printf "    ${BOLD_WHITE}beam${RESET} <space> create              ${DIM}New session (interactive)${RESET}\n"
    printf "    ${BOLD_WHITE}beam${RESET} <space> ls                  ${DIM}List sessions${RESET}\n"
    printf "    ${BOLD_WHITE}beam${RESET} <space> up    ${DIM}[session]${RESET}     ${DIM}Activate session${RESET}\n"
    printf "    ${BOLD_WHITE}beam${RESET} <space> down  ${DIM}[session]${RESET}     ${DIM}Sleep session${RESET}\n"
    printf "    ${BOLD_WHITE}beam${RESET} <space> switch ${DIM}[session]${RESET}    ${DIM}Switch (sleep conflicts)${RESET}\n"
    printf "    ${BOLD_WHITE}beam${RESET} <space> rm    ${DIM}[session]${RESET}     ${DIM}Remove session${RESET}\n"
    printf "    ${BOLD_WHITE}beam${RESET} hydrate                     ${DIM}Reconnect dead tunnels${RESET}\n"
    echo ""
}

# --- Subcommand routing ---

init_state

case "${1:-}" in
    "")
        cmd_dashboard
        ;;
    help|--help|-h)
        show_usage
        ;;
    space)
        case "${2:-}" in
            ls)
                cmd_space_ls
                ;;
            create)
                cmd_space_create "${3:-}"
                ;;
            rm)
                cmd_space_rm "${3:-}" "${4:-}"
                ;;
            *)
                show_usage
                exit 1
                ;;
        esac
        ;;
    hydrate)
        cmd_hydrate
        ;;
    *)
        local_space="$1"
        local_action="${2:-}"
        local_session="${3:-}"

        case "$local_action" in
            create)
                cmd_session_create "$local_space"
                ;;
            ls)
                cmd_session_ls "$local_space"
                ;;
            up)
                cmd_session_up "$local_space" "$local_session"
                ;;
            down)
                cmd_session_down "$local_space" "$local_session"
                ;;
            rm)
                cmd_session_rm "$local_space" "$local_session"
                ;;
            switch)
                cmd_session_switch "$local_space" "$local_session"
                ;;
            *)
                show_usage
                exit 1
                ;;
        esac
        ;;
esac
