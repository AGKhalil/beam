#!/bin/bash
# beam - Session-based SSH tunnel manager for Wasp projects

set -euo pipefail

# --- Colors & Symbols ---
if [[ -t 1 ]]; then
    BOLD='\033[1m'
    DIM='\033[2m'
    RESET='\033[0m'
    RED='\033[0;31m'
    GREEN='\033[0;32m'
    YELLOW='\033[0;33m'
    BLUE='\033[0;34m'
    CYAN='\033[0;36m'
    WHITE='\033[0;37m'
    BOLD_WHITE='\033[1;37m'
    BOLD_CYAN='\033[1;36m'
    BOLD_GREEN='\033[1;32m'
    BOLD_RED='\033[1;31m'
    BOLD_YELLOW='\033[1;33m'
else
    BOLD='' DIM='' RESET=''
    RED='' GREEN='' YELLOW='' BLUE='' CYAN='' WHITE=''
    BOLD_WHITE='' BOLD_CYAN='' BOLD_GREEN='' BOLD_RED='' BOLD_YELLOW=''
fi

SYM_LIVE="${GREEN}●${RESET}"
SYM_DORMANT="${DIM}○${RESET}"
SYM_DEAD="${RED}●${RESET}"
SYM_OK="${GREEN}✓${RESET}"
SYM_FAIL="${RED}✗${RESET}"
SYM_WARN="${YELLOW}!${RESET}"
SYM_ARROW="${DIM}->${RESET}"
SYM_SKIP="${DIM}—${RESET}"

# --- Output helpers ---
info()  { printf "  ${CYAN}%b${RESET}\n" "$*"; }
ok()    { printf "  ${GREEN}✓${RESET} %b\n" "$*"; }
err()   { printf "  ${RED}✗${RESET} %b\n" "$*" >&2; }
warn()  { printf "  ${YELLOW}!${RESET} %b\n" "$*"; }
hint()  { printf "  ${DIM}%b${RESET}\n" "$*"; }
label() { printf "${BOLD}%b${RESET}\n" "$*"; }

# --- Dependency check ---
if ! command -v jq &>/dev/null; then
    echo ""
    err "jq is required but not installed."
    hint "Install it with: brew install jq"
    echo ""
    exit 1
fi

# --- Constants ---
STATE_DIR="${HOME}/.local/state/beam"
STATE_FILE="${STATE_DIR}/state.json"

# --- State initialization ---
init_state() {
    if [[ ! -d "$STATE_DIR" ]]; then
        mkdir -p "$STATE_DIR"
    fi
    if [[ ! -f "$STATE_FILE" ]]; then
        echo '{"spaces": {}}' > "$STATE_FILE"
    fi
}

# --- State read/write helpers ---
read_state() {
    cat "$STATE_FILE"
}

write_state() {
    local new_state="$1"
    echo "$new_state" > "$STATE_FILE"
}

# --- Arrow-key selector ---
# Takes lines via stdin (one per option), renders them, lets user
# navigate with arrow keys and confirm with enter.
# Prints the 0-based index of the selected item to stdout.
# Returns 1 if user pressed q/escape with no selection.
arrow_select() {
    declare -a items
    while IFS= read -r line; do
        items+=("$line")
    done

    local count=${#items[@]}
    [[ $count -eq 0 ]] && return 1

    local cur=0

    # Hide cursor, enter raw mode
    printf "\033[?25l" >&2
    # Save tty settings and switch to raw
    local saved_tty
    saved_tty=$(stty -g </dev/tty 2>/dev/null)
    stty -echo -icanon min 1 </dev/tty 2>/dev/null

    # Draw initial list
    _arrow_draw() {
        for i in "${!items[@]}"; do
            if [[ $i -eq $cur ]]; then
                printf "  ${CYAN}>${RESET} %b\n" "${items[$i]}" >&2
            else
                printf "    %b\n" "${items[$i]}" >&2
            fi
        done
    }

    # Move cursor up N lines to redraw
    _arrow_clear() {
        for (( i=0; i<count; i++ )); do
            printf "\033[A\033[2K" >&2
        done
    }

    echo "" >&2
    _arrow_draw

    while true; do
        # Read one byte
        local key
        key=$(dd bs=1 count=1 2>/dev/null </dev/tty)

        case "$key" in
            $'\x1b')
                # Escape sequence — read next two bytes
                local seq1 seq2
                seq1=$(dd bs=1 count=1 2>/dev/null </dev/tty)
                seq2=$(dd bs=1 count=1 2>/dev/null </dev/tty)
                if [[ "$seq1" == "[" ]]; then
                    case "$seq2" in
                        A) # Up
                            if [[ $cur -gt 0 ]]; then
                                cur=$((cur - 1))
                            fi
                            ;;
                        B) # Down
                            if [[ $cur -lt $((count - 1)) ]]; then
                                cur=$((cur + 1))
                            fi
                            ;;
                    esac
                else
                    # Bare escape = cancel
                    _arrow_clear
                    stty "$saved_tty" </dev/tty 2>/dev/null
                    printf "\033[?25h" >&2
                    return 1
                fi
                ;;
            ""|$'\n')
                # Enter = confirm
                _arrow_clear
                # Show final selection
                printf "  ${CYAN}>${RESET} %b\n" "${items[$cur]}" >&2
                stty "$saved_tty" </dev/tty 2>/dev/null
                printf "\033[?25h" >&2
                echo "$cur"
                return 0
                ;;
            q|Q)
                _arrow_clear
                stty "$saved_tty" </dev/tty 2>/dev/null
                printf "\033[?25h" >&2
                return 1
                ;;
            k) # vim up
                if [[ $cur -gt 0 ]]; then
                    cur=$((cur - 1))
                fi
                ;;
            j) # vim down
                if [[ $cur -lt $((count - 1)) ]]; then
                    cur=$((cur + 1))
                fi
                ;;
        esac

        _arrow_clear
        _arrow_draw
    done
}

# --- Session selector ---
select_session() {
    local space="$1"
    local filter="${2:-}"

    local state
    state=$(read_state)

    local sessions
    sessions=$(echo "$state" | jq -r ".spaces[\"$space\"].sessions // {} | keys[]" 2>/dev/null || true)

    if [[ -z "$sessions" ]]; then
        echo ""
        return
    fi

    declare -a candidates
    declare -a display_lines
    while IFS= read -r s; do
        if [[ -n "$filter" ]]; then
            local s_status
            s_status=$(echo "$state" | jq -r ".spaces[\"$space\"].sessions[\"$s\"].status")
            [[ "$s_status" != "$filter" ]] && continue
        fi
        candidates+=("$s")

        local s_status s_host lc rc ls_port rs indicator
        s_status=$(echo "$state" | jq -r ".spaces[\"$space\"].sessions[\"$s\"].status")
        s_host=$(echo "$state" | jq -r ".spaces[\"$space\"].sessions[\"$s\"].host")
        lc=$(echo "$state" | jq -r ".spaces[\"$space\"].sessions[\"$s\"].local_client_port")
        rc=$(echo "$state" | jq -r ".spaces[\"$space\"].sessions[\"$s\"].remote_client_port")
        ls_port=$(echo "$state" | jq -r ".spaces[\"$space\"].sessions[\"$s\"].local_server_port")
        rs=$(echo "$state" | jq -r ".spaces[\"$space\"].sessions[\"$s\"].remote_server_port")

        if [[ "$s_status" == "live" ]]; then
            indicator="${GREEN}●${RESET}"
        else
            indicator="${DIM}○${RESET}"
        fi

        display_lines+=("$(printf "%b  %-30s ${DIM}%s${RESET}  ${DIM}%s:%s, %s:%s${RESET}" \
            "$indicator" "$s" "$s_host" "$lc" "$rc" "$ls_port" "$rs")")
    done <<< "$sessions"

    if [[ ${#candidates[@]} -eq 0 ]]; then
        echo ""
        return
    fi

    if [[ ${#candidates[@]} -eq 1 ]]; then
        printf "  ${DIM}auto-selected:${RESET} %s\n" "${candidates[0]}" >&2
        echo "${candidates[0]}"
        return
    fi

    local idx
    if idx=$(printf '%s\n' "${display_lines[@]}" | arrow_select); then
        echo "${candidates[$idx]}"
    else
        echo ""
    fi
}



# --- Tunnel core ---

start_tunnel() {
    local host="$1"
    local local_client="$2"
    local remote_client="$3"
    local local_server="$4"
    local remote_server="$5"

    local ssh_exit=0
    ssh -fN \
        -o ServerAliveInterval=30 \
        -o ServerAliveCountMax=3 \
        -o ExitOnForwardFailure=yes \
        -L "${local_client}:localhost:${remote_client}" \
        -L "${local_server}:localhost:${remote_server}" \
        "$host" || ssh_exit=$?

    if [[ "$ssh_exit" -ne 0 ]]; then
        echo ""
        return 1
    fi

    sleep 0.3

    local pid
    pid=$(pgrep -n -f "ssh.*-L ${local_client}:localhost:${remote_client}.*${host}" 2>/dev/null || true)

    if [[ -z "$pid" ]]; then
        echo ""
        return 1
    fi

    echo "$pid"
}

kill_tunnel() {
    local pid="$1"
    local local_client="${2:-}"
    local local_server="${3:-}"

    if [[ -z "$pid" || "$pid" == "null" ]]; then
        return 0
    fi

    if kill -0 "$pid" 2>/dev/null; then
        kill "$pid" 2>/dev/null || true
        local i=0
        while kill -0 "$pid" 2>/dev/null && [[ $i -lt 30 ]]; do
            sleep 0.1
            ((i++))
        done
    fi

    if [[ -n "$local_client" ]]; then
        local i=0
        while lsof -i ":${local_client}" -sTCP:LISTEN &>/dev/null && [[ $i -lt 30 ]]; do
            sleep 0.1
            ((i++))
        done
    fi
    if [[ -n "$local_server" ]]; then
        local i=0
        while lsof -i ":${local_server}" -sTCP:LISTEN &>/dev/null && [[ $i -lt 30 ]]; do
            sleep 0.1
            ((i++))
        done
    fi
}

check_health() {
    local pid="$1"
    local local_client="$2"
    local local_server="$3"

    if [[ -z "$pid" || "$pid" == "null" ]] || ! kill -0 "$pid" 2>/dev/null; then
        echo "dead"
        return
    fi

    if ! lsof -i ":${local_client}" -sTCP:LISTEN &>/dev/null; then
        echo "dead"
        return
    fi
    if ! lsof -i ":${local_server}" -sTCP:LISTEN &>/dev/null; then
        echo "dead"
        return
    fi

    echo "healthy"
}

find_port_conflicts() {
    local target_local_client="$1"
    local target_local_server="$2"
    local exclude_space="${3:-}"
    local exclude_session="${4:-}"

    local state
    state=$(read_state)

    local spaces
    spaces=$(echo "$state" | jq -r '.spaces | keys[]' 2>/dev/null || true)

    for space in $spaces; do
        local sessions
        sessions=$(echo "$state" | jq -r ".spaces[\"$space\"].sessions // {} | keys[]" 2>/dev/null || true)
        for session in $sessions; do
            if [[ "$space" == "$exclude_space" && "$session" == "$exclude_session" ]]; then
                continue
            fi

            local status lc ls
            status=$(echo "$state" | jq -r ".spaces[\"$space\"].sessions[\"$session\"].status" 2>/dev/null)
            if [[ "$status" != "live" ]]; then
                continue
            fi

            lc=$(echo "$state" | jq -r ".spaces[\"$space\"].sessions[\"$session\"].local_client_port" 2>/dev/null)
            ls=$(echo "$state" | jq -r ".spaces[\"$space\"].sessions[\"$session\"].local_server_port" 2>/dev/null)

            if [[ "$lc" == "$target_local_client" || "$ls" == "$target_local_server" || "$lc" == "$target_local_server" || "$ls" == "$target_local_client" ]]; then
                echo "${space}:${session}"
                return
            fi
        done
    done
}

# Helper: resolve port conflict (sleep the conflicting session)
# Returns 0 if resolved, 1 if user cancelled
resolve_conflict() {
    local state="$1"
    local conflict_space="$2"
    local conflict_session="$3"

    local cpid c_lc c_ls
    cpid=$(echo "$state" | jq -r ".spaces[\"$conflict_space\"].sessions[\"$conflict_session\"].pid // \"null\"")
    c_lc=$(echo "$state" | jq -r ".spaces[\"$conflict_space\"].sessions[\"$conflict_session\"].local_client_port")
    c_ls=$(echo "$state" | jq -r ".spaces[\"$conflict_space\"].sessions[\"$conflict_session\"].local_server_port")

    echo ""
    warn "Port conflict with ${BOLD}${conflict_session}${RESET} ${DIM}(${conflict_space})${RESET}"
    printf "  Sleep it? ${DIM}(y/n)${RESET} "
    read -r answer </dev/tty
    if [[ "$answer" == "y" || "$answer" == "Y" ]]; then
        kill_tunnel "$cpid" "$c_lc" "$c_ls"
        state=$(read_state)
        state=$(echo "$state" | jq ".spaces[\"$conflict_space\"].sessions[\"$conflict_session\"].status = \"dormant\" | .spaces[\"$conflict_space\"].sessions[\"$conflict_session\"].pid = null")
        write_state "$state"
        printf "  ${DIM}○${RESET} %s slept\n" "$conflict_session"
        return 0
    else
        hint "Cancelled."
        return 1
    fi
}

# Helper: start tunnel and update state
# Prints result line. Returns 0 on success, 1 on failure.
activate_session() {
    local space="$1"
    local session="$2"
    local host="$3"
    local lc="$4"
    local rc="$5"
    local ls="$6"
    local rs="$7"

    local pid=""
    pid=$(start_tunnel "$host" "$lc" "$rc" "$ls" "$rs" 2>&1) || true

    if [[ -n "$pid" && "$pid" != "" ]]; then
        local state
        state=$(read_state)
        state=$(echo "$state" | jq ".spaces[\"$space\"].sessions[\"$session\"].status = \"live\" | .spaces[\"$space\"].sessions[\"$session\"].pid = $pid")
        write_state "$state"
        return 0
    else
        return 1
    fi
}

# Helper: print port mapping line
print_ports() {
    local host="$1" lc="$2" rc="$3" ls="$4" rs="$5"
    printf "  ${DIM}localhost${RESET}:${BOLD_WHITE}%s${RESET} ${SYM_ARROW} %s:${DIM}%s${RESET}  ${DIM}(client)${RESET}\n" "$lc" "$host" "$rc"
    printf "  ${DIM}localhost${RESET}:${BOLD_WHITE}%s${RESET} ${SYM_ARROW} %s:${DIM}%s${RESET}  ${DIM}(server)${RESET}\n" "$ls" "$host" "$rs"
}

# --- Space management ---

cmd_space_ls() {
    local state
    state=$(read_state)
    local spaces
    spaces=$(echo "$state" | jq -r '.spaces | keys[]' 2>/dev/null || true)

    if [[ -z "$spaces" ]]; then
        echo ""
        hint "No spaces yet."
        hint "Create one: ${BOLD}beam space create <name>${RESET}"
        echo ""
        return
    fi

    echo ""
    while IFS= read -r s; do
        local count
        count=$(echo "$state" | jq ".spaces[\"$s\"].sessions | length")
        printf "  ${BOLD_WHITE}%s${RESET}  ${DIM}(%d sessions)${RESET}\n" "$s" "$count"
    done <<< "$spaces"
    echo ""
}

cmd_space_create() {
    local name="$1"

    if [[ -z "$name" ]]; then
        err "Missing name"
        hint "Usage: beam space create <name>"
        exit 1
    fi

    local state
    state=$(read_state)

    local exists
    exists=$(echo "$state" | jq -r ".spaces[\"$name\"] // \"null\"")
    if [[ "$exists" != "null" ]]; then
        err "Space '${name}' already exists."
        exit 1
    fi

    state=$(echo "$state" | jq ".spaces[\"$name\"] = {\"sessions\": {}}")
    write_state "$state"
    echo ""
    ok "Space ${BOLD}${name}${RESET} created"
    echo ""
}

cmd_space_rm() {
    local name="$1"
    local force="${2:-}"

    if [[ -z "$name" ]]; then
        err "Missing name"
        hint "Usage: beam space rm <name> [--force]"
        exit 1
    fi

    local state
    state=$(read_state)

    local exists
    exists=$(echo "$state" | jq -r ".spaces[\"$name\"] // \"null\"")
    if [[ "$exists" == "null" ]]; then
        err "Space '${name}' does not exist."
        exit 1
    fi

    local session_count
    session_count=$(echo "$state" | jq ".spaces[\"$name\"].sessions | length")

    if [[ "$session_count" -gt 0 && "$force" != "--force" ]]; then
        err "Space '${name}' has ${session_count} session(s)."
        hint "Use --force to remove."
        exit 1
    fi

    if [[ "$session_count" -gt 0 && "$force" == "--force" ]]; then
        local sessions
        sessions=$(echo "$state" | jq -r ".spaces[\"$name\"].sessions | keys[]" 2>/dev/null || true)
        for session in $sessions; do
            local pid s_lc s_ls
            pid=$(echo "$state" | jq -r ".spaces[\"$name\"].sessions[\"$session\"].pid // \"null\"")
            s_lc=$(echo "$state" | jq -r ".spaces[\"$name\"].sessions[\"$session\"].local_client_port")
            s_ls=$(echo "$state" | jq -r ".spaces[\"$name\"].sessions[\"$session\"].local_server_port")
            local status
            status=$(echo "$state" | jq -r ".spaces[\"$name\"].sessions[\"$session\"].status")
            if [[ "$status" == "live" && "$pid" != "null" ]]; then
                kill_tunnel "$pid" "$s_lc" "$s_ls"
                printf "  ${DIM}○${RESET} killed %s\n" "$session"
            fi
        done
    fi

    state=$(echo "$state" | jq "del(.spaces[\"$name\"])")
    write_state "$state"
    echo ""
    ok "Space ${BOLD}${name}${RESET} removed"
    echo ""
}

# --- Session lifecycle ---

cmd_session_create() {
    local space="$1"

    local state
    state=$(read_state)

    local exists
    exists=$(echo "$state" | jq -r ".spaces[\"$space\"] // \"null\"")
    if [[ "$exists" == "null" ]]; then
        err "Space '${space}' does not exist."
        exit 1
    fi

    echo ""
    printf "  ${BOLD}SSH host${RESET} ${DIM}(e.g. ag@hetzner1)${RESET}: "
    read -r host
    if [[ -z "$host" ]]; then
        err "SSH host is required."
        exit 1
    fi

    local short_host
    short_host=$(echo "$host" | sed 's/.*@//')

    printf "  ${DIM}Scanning %s...${RESET}" "$host"
    local dirlist
    dirlist=$(ssh -o ConnectTimeout=10 "$host" 'ls -1d ~/codebases/*/ 2>/dev/null | while read d; do basename "$d"; done | sort')
    printf "\r\033[K"

    if [[ -z "$dirlist" ]]; then
        err "No projects found in ~/codebases on ${host}."
        exit 1
    fi

    declare -a proj_arr
    while IFS= read -r dir; do
        if [[ "$dir" == *"."* ]]; then
            local base="${dir%%.*}"
            if echo "$dirlist" | grep -qx "$base"; then
                continue
            fi
        fi
        proj_arr+=("$dir")
    done <<< "$dirlist"

    echo ""
    label "  Projects"

    declare -a proj_display
    for proj in "${proj_arr[@]}"; do
        local count=0
        while IFS= read -r dir; do
            if [[ "$dir" == "${proj}."* ]]; then
                count=$((count + 1))
            fi
        done <<< "$dirlist"

        if [[ "$count" -gt 0 ]]; then
            proj_display+=("$(printf "%-25s ${DIM}%d worktrees${RESET}" "$proj" "$count")")
        else
            proj_display+=("$proj")
        fi
    done

    local project=""
    if [[ ${#proj_arr[@]} -eq 1 ]]; then
        project="${proj_arr[0]}"
    else
        local proj_idx
        if proj_idx=$(printf '%s\n' "${proj_display[@]}" | arrow_select); then
            project="${proj_arr[$proj_idx]}"
        fi
    fi
    if [[ -z "$project" ]]; then
        hint "No project selected."
        exit 1
    fi

    declare -a wt_arr
    while IFS= read -r dir; do
        if [[ "$dir" == "${project}."* ]]; then
            wt_arr+=("$dir")
        fi
    done <<< "$dirlist"

    if [[ ${#wt_arr[@]} -eq 0 ]]; then
        err "No worktrees found for ${project}."
        exit 1
    fi

    local grep_cmd=""
    for wt in "${wt_arr[@]}"; do
        grep_cmd="${grep_cmd}echo \"${wt}|\$(grep '^WASP_CLIENT_PORT=' ~/codebases/${wt}/.env 2>/dev/null | cut -d= -f2 || echo none)\";"
    done
    local wt_ports
    wt_ports=$(ssh -o ConnectTimeout=10 "$host" "$grep_cmd")

    echo ""
    label "  Worktrees"

    declare -a wt_values wt_display
    while IFS= read -r line; do
        [[ -z "$line" ]] && continue
        local wt port
        wt=$(echo "$line" | cut -d'|' -f1)
        port=$(echo "$line" | cut -d'|' -f2 | tr -d '[:space:]')
        wt_values+=("$wt")
        if [[ -n "$port" && "$port" != "none" ]]; then
            wt_display+=("$(printf "%-30s ${DIM}client:%s${RESET}" "$wt" "$port")")
        else
            wt_display+=("$(printf "%-30s ${DIM}no .env${RESET}" "$wt")")
        fi
    done <<< "$wt_ports"

    local worktree=""
    if [[ ${#wt_values[@]} -eq 1 ]]; then
        worktree="${wt_values[0]}"
    else
        local wt_idx
        if wt_idx=$(printf '%s\n' "${wt_display[@]}" | arrow_select); then
            worktree="${wt_values[$wt_idx]}"
        fi
    fi
    if [[ -z "$worktree" ]]; then
        hint "No worktree selected."
        exit 1
    fi

    local remote_env
    remote_env=$(ssh -o ConnectTimeout=10 "$host" "cat ~/codebases/$worktree/.env 2>/dev/null")

    if [[ -z "$remote_env" ]]; then
        err "Could not read ~/codebases/${worktree}/.env on ${host}"
        exit 1
    fi

    local client_port server_port
    client_port=$(echo "$remote_env" | grep '^WASP_CLIENT_PORT=' | cut -d= -f2 | tr -d '[:space:]')
    server_port=$(echo "$remote_env" | grep '^WASP_SERVER_PORT=' | cut -d= -f2 | tr -d '[:space:]')

    if [[ -z "$client_port" || -z "$server_port" ]]; then
        err "Missing WASP_CLIENT_PORT or WASP_SERVER_PORT in .env"
        exit 1
    fi

    echo ""
    printf "  ${DIM}Remote ports: client=%s, server=%s${RESET}\n" "$client_port" "$server_port"
    printf "  ${BOLD}Local client port${RESET} ${DIM}[3000]${RESET}: "
    read -r local_client
    local_client="${local_client:-3000}"
    printf "  ${BOLD}Local server port${RESET} ${DIM}[3001]${RESET}: "
    read -r local_server
    local_server="${local_server:-3001}"

    local session_name="${short_host}:${worktree}"

    local session_exists
    session_exists=$(echo "$state" | jq -r ".spaces[\"$space\"].sessions[\"$session_name\"] // \"null\"")
    if [[ "$session_exists" != "null" ]]; then
        err "Session '${session_name}' already exists in space '${space}'."
        exit 1
    fi

    # Check for port conflicts
    local conflict
    conflict=$(find_port_conflicts "$local_client" "$local_server" "$space" "$session_name")
    if [[ -n "$conflict" ]]; then
        local conflict_space conflict_session
        conflict_space=$(echo "$conflict" | cut -d: -f1)
        conflict_session=$(echo "$conflict" | cut -d: -f2-)
        resolve_conflict "$state" "$conflict_space" "$conflict_session" || exit 0
    fi

    # Create session in state
    state=$(read_state)
    state=$(echo "$state" | jq ".spaces[\"$space\"].sessions[\"$session_name\"] = {
        \"host\": \"$host\",
        \"project\": \"$project\",
        \"worktree\": \"$worktree\",
        \"remote_client_port\": $client_port,
        \"remote_server_port\": $server_port,
        \"local_client_port\": $local_client,
        \"local_server_port\": $local_server,
        \"status\": \"dormant\",
        \"pid\": null
    }")
    write_state "$state"

    echo ""
    printf "  ${DIM}Connecting...${RESET}"
    if activate_session "$space" "$session_name" "$host" "$local_client" "$client_port" "$local_server" "$server_port"; then
        printf "\r\033[K"
        ok "${BOLD}${session_name}${RESET} created and live"
        print_ports "$host" "$local_client" "$client_port" "$local_server" "$server_port"
    else
        printf "\r\033[K"
        warn "${BOLD}${session_name}${RESET} created but tunnel failed"
        hint "Try: beam ${space} up"
    fi
    echo ""
}

cmd_session_ls() {
    local space="$1"

    local state
    state=$(read_state)

    local exists
    exists=$(echo "$state" | jq -r ".spaces[\"$space\"] // \"null\"")
    if [[ "$exists" == "null" ]]; then
        err "Space '${space}' does not exist."
        exit 1
    fi

    local sessions
    sessions=$(echo "$state" | jq -r ".spaces[\"$space\"].sessions // {} | keys[]" 2>/dev/null || true)

    if [[ -z "$sessions" ]]; then
        echo ""
        hint "No sessions in ${BOLD}${space}${RESET}."
        hint "Create one: ${BOLD}beam ${space} create${RESET}"
        echo ""
        return
    fi

    echo ""
    printf "  ${DIM}%-2s  %-32s %-18s %-20s %s${RESET}\n" "" "SESSION" "HOST" "PORTS" "STATUS"
    echo ""

    while IFS= read -r session; do
        local s_host s_status lc ls_port rc rs
        s_host=$(echo "$state" | jq -r ".spaces[\"$space\"].sessions[\"$session\"].host")
        s_status=$(echo "$state" | jq -r ".spaces[\"$space\"].sessions[\"$session\"].status")
        lc=$(echo "$state" | jq -r ".spaces[\"$space\"].sessions[\"$session\"].local_client_port")
        ls_port=$(echo "$state" | jq -r ".spaces[\"$space\"].sessions[\"$session\"].local_server_port")
        rc=$(echo "$state" | jq -r ".spaces[\"$space\"].sessions[\"$session\"].remote_client_port")
        rs=$(echo "$state" | jq -r ".spaces[\"$space\"].sessions[\"$session\"].remote_server_port")

        local indicator status_str ports
        if [[ "$s_status" == "live" ]]; then
            indicator="${GREEN}●${RESET}"
            status_str="${GREEN}live${RESET}"
            ports="${lc}:${rc}, ${ls_port}:${rs}"
        else
            indicator="${DIM}○${RESET}"
            status_str="${DIM}dormant${RESET}"
            ports="${DIM}${lc}:${rc}, ${ls_port}:${rs}${RESET}"
        fi

        printf "  %b  %-32s ${DIM}%-18s${RESET} %-20b %b\n" "$indicator" "$session" "$s_host" "$ports" "$status_str"
    done <<< "$sessions"
    echo ""
}

cmd_session_up() {
    local space="$1"
    local session="${2:-}"

    if [[ -z "$session" ]]; then
        printf "\n  ${BOLD}Activate session${RESET} ${DIM}(${space})${RESET}\n"
        session=$(select_session "$space" "dormant")
        if [[ -z "$session" ]]; then
            hint "No dormant sessions."
            echo ""
            return
        fi
    fi

    local state
    state=$(read_state)

    local exists
    exists=$(echo "$state" | jq -r ".spaces[\"$space\"] // \"null\"")
    if [[ "$exists" == "null" ]]; then
        err "Space '${space}' does not exist."
        exit 1
    fi

    local session_data
    session_data=$(echo "$state" | jq -r ".spaces[\"$space\"].sessions[\"$session\"] // \"null\"")
    if [[ "$session_data" == "null" ]]; then
        err "Session '${session}' does not exist in space '${space}'."
        exit 1
    fi

    local status
    status=$(echo "$state" | jq -r ".spaces[\"$space\"].sessions[\"$session\"].status")
    if [[ "$status" == "live" ]]; then
        echo ""
        hint "Already live."
        echo ""
        return
    fi

    local host lc ls rc rs
    host=$(echo "$state" | jq -r ".spaces[\"$space\"].sessions[\"$session\"].host")
    lc=$(echo "$state" | jq -r ".spaces[\"$space\"].sessions[\"$session\"].local_client_port")
    ls=$(echo "$state" | jq -r ".spaces[\"$space\"].sessions[\"$session\"].local_server_port")
    rc=$(echo "$state" | jq -r ".spaces[\"$space\"].sessions[\"$session\"].remote_client_port")
    rs=$(echo "$state" | jq -r ".spaces[\"$space\"].sessions[\"$session\"].remote_server_port")

    local conflict
    conflict=$(find_port_conflicts "$lc" "$ls" "$space" "$session")
    if [[ -n "$conflict" ]]; then
        local conflict_space conflict_session
        conflict_space=$(echo "$conflict" | cut -d: -f1)
        conflict_session=$(echo "$conflict" | cut -d: -f2-)
        resolve_conflict "$state" "$conflict_space" "$conflict_session" || return
    fi

    echo ""
    printf "  ${DIM}Connecting...${RESET}"
    if activate_session "$space" "$session" "$host" "$lc" "$rc" "$ls" "$rs"; then
        printf "\r\033[K"
        ok "${BOLD}${session}${RESET} is live"
        print_ports "$host" "$lc" "$rc" "$ls" "$rs"
    else
        printf "\r\033[K"
        err "Failed to start tunnel."
    fi
    echo ""
}

